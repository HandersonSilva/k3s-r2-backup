{
    "name": "local/k3s-r2-backup",
    "description": "Standalone CLI: compacta token e server/db do K3s e envia para Cloudflare R2 (S3-compatible).",
    "license": "proprietary",
    "require": {
        "php": "^7.4",
        "aws/aws-sdk-php": "3.269.14",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "audit": {
            "block-insecure": false
        },
        "platform": {
            "php": "7.4.3"
        },
        "sort-packages": true
    }
}
