# Mesmas variáveis que o disco "r2" em config/filesystems.php do projeto database-backup.
# Copie para .env e preencha. Não commite .env.
# Em alguns PHP CLI, variáveis exportadas no shell só aparecem via getenv(); o script
# suporta .env (Dotenv) e export no shell.

CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_REGION=us-east-1
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_URL=
CLOUDFLARE_R2_PREFIX=
CLOUDFLARE_R2_ENDPOINT=

# Opcional: caminhos no nó de controlo (omissão = padrão K3s)
# K3S_SERVER_TOKEN_PATH=/var/lib/rancher/k3s/server/token
# K3S_SERVER_DB_DIR=/var/lib/rancher/k3s/server/db

# Opcional: restore-k3s-from-r2.php — chave S3 completa do objeto (sobrepõe a escolha automática do mais recente)
# K3S_RESTORE_OBJECT_KEY=
